{
  "imports": {
    "pg": "npm:pg@^8"
  },
  "tasks": {
    "export": "python -X utf8 tools/export_catalog.py",
    "migrate": "deno run --allow-net --allow-read --allow-env migrate.ts",
    "start": "deno run --allow-net --allow-read --allow-env --allow-sys server.ts",
    "check": "deno check server.ts migrate.ts"
  },
  "deploy": {
    "project": "ai-learning-deno-cloud",
    "exclude": [
      ".git",
      ".vscode",
      "tools"
    ],
    "include": [
      "server.ts",
      "migrate.ts",
      "deno.json",
      "schema.postgres.sql",
      "*.html",
      "assets/**/*",
      "data/catalog.json"
    ],
    "entrypoint": "server.ts"
  }
}
