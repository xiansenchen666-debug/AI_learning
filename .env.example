# Preferred: Deno Deploy injects this automatically for an attached SQL database.
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/ai_learning

# Or use standard PostgreSQL variables for local development:
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=ai_learning
PGPOOL_MAX=10

# Optional: object storage base URL for large resources.
# Keep this empty for local development against ../AI_learning_bendi/resources.
RESOURCE_BASE_URL=

# Optional HTTP port for local Deno run.
PORT=8000

# Default AI model settings. A teacher's saved configuration is encrypted and
# takes precedence over these fallback values.
AI_BASE_URL=https://meapi.space
AI_MODEL=gpt-5.2
AI_API_KEY=
AI_ALLOWED_HOSTS=meapi.space

# Optional daily cost guards. Values below are the built-in defaults.
AI_USER_DAILY_REQUEST_LIMIT=20
AI_GLOBAL_DAILY_REQUEST_LIMIT=200
AI_USER_DAILY_TOKEN_LIMIT=500000
AI_GLOBAL_DAILY_TOKEN_LIMIT=5000000

# Strong, stable secret used to encrypt API keys saved from the teacher console.
# Set a different value in each deployed environment and do not commit it.
AI_CONFIG_ENCRYPTION_KEY=

# Production-only strong password for the seeded teacher account. When set,
# migration upgrades the known default teacher password without overwriting an
# already customized password. Use at least 12 characters and keep it secret.
DEFAULT_TEACHER_PASSWORD=
