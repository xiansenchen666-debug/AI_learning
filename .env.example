# Either use one DATABASE_URL:
DATABASE_URL=mysql://root:password@127.0.0.1:3306/ai_learning

# Or use split MySQL variables:
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=ai_learning
MYSQL_CONNECTION_LIMIT=10

# Optional: object storage base URL for large resources.
# Keep this empty for local development against ../AI_learning_bendi/resources.
RESOURCE_BASE_URL=

# Optional HTTP port for local Deno run.
PORT=8000
