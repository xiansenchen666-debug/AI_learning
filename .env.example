# Preferred: Deno Deploy injects this automatically for an attached SQL database.
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/ai_learning

# Or use standard PostgreSQL variables for local development:
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
PGDATABASE=ai_learning
PGPOOL_MAX=10

# Optional: object storage base URL for large resources.
# Keep this empty for local development against ../AI_learning_bendi/resources.
RESOURCE_BASE_URL=

# Optional HTTP port for local Deno run.
PORT=8000
